{
    "name": "a21/lexicon-client",
    "description": "Laravel client for Lexicon: export, pull, and import translations with a central Lexicon server.",
    "version": "1.2.0",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "lexicon",
        "translation",
        "i18n",
        "localization",
        "a21"
    ],
    "authors": [
        {
            "name": "A21",
            "homepage": "https://github.com/A21-Center"
        }
    ],
    "homepage": "https://github.com/A21-Center/lexicon-client",
    "support": {
        "issues": "https://github.com/A21-Center/lexicon-client/issues",
        "source": "https://github.com/A21-Center/lexicon-client"
    },
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "A21\\LexiconClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "A21\\LexiconClient\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "A21\\LexiconClient\\LexiconClientServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
